DD_API_KEY=replace-with-your-datadog-api-key
DD_SITE=datadoghq.com
DD_ENV=dev
DD_SERVICE=datadog-pc-telemetry-sample

# Optional:
# DD_HOSTNAME=my-laptop
# DD_TAGS=team:platform,owner:local-dev
# METRIC_PREFIX=sample.pc

# Optional: log status thresholds (percent)
# CPU_WARN_PERCENT=70
# CPU_ERROR_PERCENT=90
# MEMORY_WARN_PERCENT=85
# MEMORY_ERROR_PERCENT=95
